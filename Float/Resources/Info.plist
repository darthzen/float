<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>Float</string>
    <key>CFBundleDisplayName</key>
    <string>Float</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>

    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <true/>
    </dict>

    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>arkit</string>
    </array>

    <!-- Hand tracking authorization prompt (§7 double-pinch, §7f flick).
         VERIFY the exact key name against the current visionOS 27 SDK before shipping. -->
    <key>NSHandsTrackingUsageDescription</key>
    <string>Float uses hand tracking so you can open controls with a double-pinch and flick asteroids.</string>

    <!-- Spatial sensing for the immersive scene. -->
    <key>NSWorldSensingUsageDescription</key>
    <string>Float uses spatial sensing to render the immersive space around you.</string>
</dict>
</plist>
